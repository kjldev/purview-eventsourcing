{
  "name": "purview-eventsourcing-release",
  "private": true,
  "version": "1.1.1",
  "scripts": {
    "release": "commit-and-tag-version --commit-all"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "commit-and-tag-version": "^12.7.1"
  },
  "commit-and-tag-version": {
    "skip": {
      "tag": true
    },
    "bumpFiles": [
      "package.json",
      {
        "filename": "package-lock.json",
        "type": "json"
      }
    ]
  }
}

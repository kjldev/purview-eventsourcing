<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<Target
		Name="ValidateRootNamespacePrefixTarget"
		BeforeTargets="Compile"
		Label="Validates the NamespacePrefix Prefix is set."
		Condition="'$(DisableNamespacePrefixCheck)' != 'true'"
	>
		<Error
			Text="The NamespacePrefix property has not been set. To fix, set the `NamespacePrefix` in the `PropertyGroup` of either the .csproj file, or a Directory.Build.props file. You can disable this check by setting 'DisableNamespacePrefixCheck' to 'true'."
			ContinueOnError="false"
			Condition="'$(NamespacePrefix)' == ''"
			Code="NamespacePrefixNoSet"
			File="$(MSBuildProjectFile)"
		/>
	</Target>
	<Target
		Name="InternalsVisibleToTarget"
		BeforeTargets="BeforeCompile"
		Condition="$(IsCSharpProject) AND !$(IsTestProject)"
		Label="Generates `InternalsVisibleToAttribute` for Non-Test Projects based on Defined Testing Types"
	>
		<ItemGroup>
			<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
				<_Parameter1>$(MSBuildProjectName).%(TestType.Identity)Tests</_Parameter1>
			</AssemblyAttribute>
		</ItemGroup>
	</Target>
	<Target
		Name="GenerateAssemblyInfoClassTarget"
		BeforeTargets="BeforeCompile"
		Condition="$(IsCSharpProject) AND !$(DisableGenerateAssemblyInfoClass)"
	>
		<WriteLinesToFile
			File="$(IntermediateOutputPath)/Properties/$(AutoGeneratedAssemblyInfoFile)"
			Lines="namespace $(RootNamespace)%3B

static class AssemblyInfo
{
    public const string RootNamespace = &quot;$(RootNamespace)&quot;%3B
    public const string AssemblyName = &quot;$(AssemblyName)&quot;%3B
    public const string AssemblyTitle = &quot;$(AssemblyTitle)&quot;%3B
    public const string AssemblyProduct = &quot;$(AssemblyProduct)&quot;%3B
    public const string Version = &quot;$(Version)&quot;%3B
    public const string Company = &quot;$(Company)&quot;%3B
    public const string Copyright = &quot;$(Copyright)&quot;%3B
    public const int Year = $(CurrentYear)%3B

	public static string GetFriendlyName()
	{
		var possibles = new[]
		{
			AssemblyProduct,
			AssemblyTitle,
			AssemblyName
		}%3B

		foreach (var name in possibles)
		{
			if (!string.IsNullOrWhiteSpace(name))
			{
				return name%3B
			}
		}

		return &quot;$(MSBuildProjectName)&quot;%3B
	}
}
"
			Overwrite="true"
		/>
		<ItemGroup>
			<Compile Include="$(IntermediateOutputPath)/Properties/$(AutoGeneratedAssemblyInfoFile)" />
		</ItemGroup>
	</Target>
</Project>

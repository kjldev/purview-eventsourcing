<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>Purview.EventSourcing.Samples.QuickStart</RootNamespace>
		<ExcludePurviewTelemetry>true</ExcludePurviewTelemetry>
		<NoWarn>$(NoWarn);CA1515;CA1062;CA1303;CA1307;CA1308;</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\EventSourcing.Samples\EventSourcing.Samples.csproj" />
		<ProjectReference Include="..\..\src\EventSourcing\EventSourcing.csproj" />
		<ProjectReference
			Include="..\..\src\EventSourcing.SourceGenerator\EventSourcing.SourceGenerator.csproj"
			OutputItemType="Analyzer"
			ReferenceOutputAssembly="false"
		/>
	</ItemGroup>
</Project>

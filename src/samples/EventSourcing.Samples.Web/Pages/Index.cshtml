@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center gap-4">
        <div class="text-4xl">👤</div>
        <div>
            <p class="text-3xl font-bold text-slate-800">@Model.CustomerCount</p>
            <p class="text-sm text-gray-500 mt-1">Customers</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center gap-4">
        <div class="text-4xl">📦</div>
        <div>
            <p class="text-3xl font-bold text-slate-800">@Model.OrderCount</p>
            <p class="text-sm text-gray-500 mt-1">Orders</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center gap-4">
        <div class="text-4xl">🏭</div>
        <div>
            <p class="text-3xl font-bold text-slate-800">@Model.InventoryCount</p>
            <p class="text-sm text-gray-500 mt-1">Inventory Items</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">Customers</h2>
        <p class="text-sm text-gray-500 mb-4">Manage customer profiles with email, phone, and active status.</p>
        <a asp-page="/Customers/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">View Customers →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">Orders</h2>
        <p class="text-sm text-gray-500 mb-4">Full order lifecycle: Draft → Confirmed → Shipped → Completed.</p>
        <a asp-page="/Orders/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">View Orders →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">Inventory</h2>
        <p class="text-sm text-gray-500 mb-4">Track stock levels, reservations, and shipments per product.</p>
        <a asp-page="/Inventory/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">View Inventory →</a>
    </div>
</div>

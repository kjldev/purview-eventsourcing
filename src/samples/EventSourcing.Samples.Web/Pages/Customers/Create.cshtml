@page
@model Purview.EventSourcing.Samples.Web.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Register Customer";
}

<div class="max-w-lg">
    <a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Customers</a>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <h2 class="text-lg font-semibold mb-6">Register New Customer</h2>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="mb-4 text-red-600 text-sm"></div>
            <div class="space-y-4">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="mt-6 flex gap-3">
                <button type="submit" class="px-6 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Register</button>
                <a asp-page="Index" class="px-6 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">Cancel</a>
            </div>
        </form>
    </div>
</div>

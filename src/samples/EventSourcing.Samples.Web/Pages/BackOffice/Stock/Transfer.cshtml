@page
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Stock.TransferModel
@{
    ViewData["Title"] = "Transfer Stock";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-page="Index" class="text-sm text-slate-600 hover:underline">← Back to Stock</a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900">Transfer Stock</h2>
            <p class="mt-1 text-sm text-gray-500">
                Demonstrates multi-aggregate coordination using the <strong>saga compensation pattern</strong>.
            </p>
        </div>

        <div asp-validation-summary="ModelOnly" class="mb-5 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"></div>

        <form method="post">
            <div class="space-y-5">
                <div>
                    <label asp-for="SourceId" class="block text-sm font-medium text-gray-700 mb-1">Transfer From</label>
                    @if (Model.InventoryItems.Count == 0)
                    {
                        <p class="text-sm text-red-500">No inventory items available.</p>
                    }
                    else
                    {
                        <select asp-for="SourceId" asp-items="Model.InventoryItems"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400">
                            <option value="">— Select source —</option>
                        </select>
                        <span asp-validation-for="SourceId" class="text-red-500 text-xs mt-1 block"></span>
                    }
                </div>
                <div>
                    <label asp-for="DestinationId" class="block text-sm font-medium text-gray-700 mb-1">Transfer To</label>
                    @if (Model.InventoryItems.Count == 0)
                    {
                        <p class="text-sm text-red-500">No inventory items available.</p>
                    }
                    else
                    {
                        <select asp-for="DestinationId" asp-items="Model.InventoryItems"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400">
                            <option value="">— Select destination —</option>
                        </select>
                        <span asp-validation-for="DestinationId" class="text-red-500 text-xs mt-1 block"></span>
                    }
                </div>
                <div>
                    <label asp-for="Quantity" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                    <input asp-for="Quantity" type="number" min="1"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
                    <span asp-validation-for="Quantity" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Reason" class="block text-sm font-medium text-gray-700 mb-1">Reason</label>
                    <input asp-for="Reason" type="text" placeholder="e.g. Warehouse consolidation"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
                    <span asp-validation-for="Reason" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="mt-6 flex gap-3">
                <button type="submit"
                        class="px-6 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-500 transition-colors"
                        @(Model.InventoryItems.Count < 2 ? "disabled" : "")>
                    ⇌ Transfer Stock
                </button>
                <a asp-page="Index" class="px-6 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancel</a>
            </div>
        </form>
    </div>
</div>

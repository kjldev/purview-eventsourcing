@page
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Stock.CreateModel
@{
    ViewData["Title"] = "Add Stock Item";
}

<div class="max-w-lg">
    <a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Stock</a>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <h2 class="text-lg font-semibold mb-6">Initialize Stock Item</h2>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="mb-4 text-red-600 text-sm"></div>
            <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="ProductId" class="block text-sm font-medium text-gray-700 mb-1">Product ID *</label>
                        <input asp-for="ProductId" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" placeholder="e.g. SKU-001" />
                        <span asp-validation-for="ProductId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="LocationId" class="block text-sm font-medium text-gray-700 mb-1">Location ID *</label>
                        <input asp-for="LocationId" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" placeholder="e.g. WH-A" />
                        <span asp-validation-for="LocationId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="ProductName" class="block text-sm font-medium text-gray-700 mb-1">Product Name *</label>
                    <input asp-for="ProductName" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
                    <span asp-validation-for="ProductName" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="LocationName" class="block text-sm font-medium text-gray-700 mb-1">Location Name *</label>
                    <input asp-for="LocationName" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" placeholder="e.g. Warehouse A" />
                    <span asp-validation-for="LocationName" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="InitialQuantity" class="block text-sm font-medium text-gray-700 mb-1">Initial Quantity</label>
                    <input asp-for="InitialQuantity" type="number" min="0" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
                    <span asp-validation-for="InitialQuantity" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="mt-6 flex gap-3">
                <button type="submit" class="px-6 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Initialize</button>
                <a asp-page="Index" class="px-6 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">Cancel</a>
            </div>
        </form>
    </div>
</div>

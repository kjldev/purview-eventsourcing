@page "{id}"
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Catalog.EditModel
@{
    ViewData["Title"] = $"Catalog Edit — {Model.Item?.ProductName}";
}

@if (Model.Item == null)
{
    <p class="text-gray-500">Inventory item not found.</p>
    return;
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Catalog</a>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Update Product Name -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Update Product Name</h2>
        <form method="post" asp-page-handler="UpdateProductName">
            <input type="hidden" name="id" value="@Model.Item.Id()" />
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Product Name</label>
                <input name="productName" type="text" value="@Model.Item.ProductName"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Product Name</button>
        </form>
    </div>

    <!-- Physical Location -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Physical Location</h2>
        <dl class="space-y-3 text-sm">
            <div>
                <dt class="font-medium text-gray-700">Location Name</dt>
                <dd class="text-gray-600">@Model.Item.LocationName</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-700">Location ID</dt>
                <dd class="font-mono text-xs text-gray-500">@Model.Item.LocationId</dd>
            </div>
        </dl>
        <p class="mt-4 text-xs text-gray-500">
            Physical locations are now managed separately from individual inventory items.
        </p>
    </div>

    <!-- Product Image -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:col-span-2">
        <h2 class="text-base font-semibold mb-4">Product Image</h2>
        <div class="flex items-start gap-6">
            <div class="w-36 h-36 rounded-lg overflow-hidden border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center">
                @if (Model.CurrentImageUrl != null)
                {
                    <img src="@Model.CurrentImageUrl" alt="@Model.Item.ProductName" class="w-full h-full object-cover" />
                }
                else
                {
                    <span class="text-4xl">📦</span>
                }
            </div>
            <div class="flex-1 space-y-4">
                <form method="post" asp-page-handler="UploadImage" enctype="multipart/form-data">
                    <input type="hidden" name="id" value="@Model.Item.Id()" />
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Upload new image</label>
                        <input type="file" name="imageFile" accept="image/jpeg,image/png,image/webp,image/gif"
                               class="block w-full text-sm text-gray-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200" />
                        <p class="text-xs text-gray-400 mt-1">JPEG, PNG, WebP or GIF. Image is shared across all locations for this product.</p>
                    </div>
                    <button type="submit" class="px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Upload Image</button>
                </form>
                @if (Model.CurrentImageUrl != null)
                {
                    <form method="post" asp-page-handler="DeleteImage">
                        <input type="hidden" name="id" value="@Model.Item.Id()" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-sm text-red-500 hover:text-red-700 hover:underline"
                                onclick="return confirm('Remove the product image?')">Remove image</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-6 bg-gray-50 rounded-xl border border-gray-100 p-4 text-sm text-gray-600">
    <span class="font-medium">@Model.Item.ProductName</span> ·
    <span class="font-mono text-xs">@Model.Item.ProductId</span> ·
    <span class="text-gray-500">@Model.Item.LocationName</span> ·
    <span class="font-mono text-xs text-gray-400">v@(Model.Item.Details.SavedVersion)</span>
</div>

@page
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Catalog.IndexModel
@{
    ViewData["Title"] = "Catalog";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">@Model.TotalCount item(s) — page @Model.Page of @Model.TotalPages</p>
    <div class="flex gap-3">
        <a asp-page="Deleted" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">🗄 Archived</a>
        <a asp-page="/BackOffice/Stock/Transfer" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">⇌ Transfer</a>
        <a asp-page="Create" class="px-4 py-2 text-sm bg-slate-700 text-white rounded-lg hover:bg-slate-600 transition-colors">+ Add Item</a>
    </div>
</div>

<form method="get" class="mb-6 flex gap-3">
    <input type="hidden" name="sortBy" value="@Model.SortBy" />
    <input type="hidden" name="sortDir" value="@Model.SortDir" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <input type="text" name="search" value="@Model.Search" placeholder="Search by product name or ID..."
           class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
    <button type="submit" class="px-4 py-2 bg-slate-100 text-slate-700 text-sm rounded-lg hover:bg-slate-200 transition-colors">Search</button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a asp-page="Index" class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 underline self-center">Clear</a>
    }
</form>

@if (Model.Items.Count == 0)
{
    <div class="text-center py-16 text-gray-400">
        <p class="text-5xl mb-3">📦</p>
        <p class="text-lg font-medium">No inventory items found</p>
    </div>
}
else
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">
                        <a asp-page="Index" asp-all-route-data='@(new Dictionary<string,string>{["search"]=Model.Search??"",["sortBy"]="productid",["sortDir"]=Model.SortLink("productid"),["pageSize"]=Model.PageSize.ToString()})' class="hover:text-slate-800">Product ID @Model.SortIcon("productid")</a>
                    </th>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">
                        <a asp-page="Index" asp-all-route-data='@(new Dictionary<string,string>{["search"]=Model.Search??"",["sortBy"]="name",["sortDir"]=Model.SortLink("name"),["pageSize"]=Model.PageSize.ToString()})' class="hover:text-slate-800">Product Name @Model.SortIcon("name")</a>
                    </th>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">
                        <a asp-page="Index" asp-all-route-data='@(new Dictionary<string,string>{["search"]=Model.Search??"",["sortBy"]="location",["sortDir"]=Model.SortLink("location"),["pageSize"]=Model.PageSize.ToString()})' class="hover:text-slate-800">Location @Model.SortIcon("location")</a>
                    </th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">On Hand</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Available</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Ver</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model.Items)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-5 py-3 font-mono text-xs text-gray-500">@item.ProductId</td>
                        <td class="px-5 py-3 font-medium">@item.ProductName</td>
                        <td class="px-5 py-3 text-gray-600">@item.LocationName <span class="text-xs text-gray-400">(@item.LocationId)</span></td>
                        <td class="px-5 py-3 text-right">@item.QuantityOnHand</td>
                        <td class="px-5 py-3 text-right @(item.AvailableQuantity <= 0 ? "text-red-600 font-semibold" : "text-green-700")">@item.AvailableQuantity</td>
                        <td class="px-5 py-3 text-right text-gray-400 font-mono text-xs">v@(item.Details.SavedVersion)</td>
                        <td class="px-5 py-3 text-right whitespace-nowrap">
                            <a asp-page="Edit" asp-route-id="@item.Id()" class="text-slate-600 hover:underline mr-3">Edit</a>
                            <form method="post" asp-page-handler="Archive" asp-route-id="@item.Id()" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-red-400 hover:text-red-600 hover:underline"
                                        onclick="return confirm('Archive this item?')">Archive</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between mt-4 text-sm text-gray-600">
        <span>Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, (int)Model.TotalCount)) of @Model.TotalCount</span>
        <div class="flex gap-2">
            @if (Model.HasPrevPage)
            {
                <a href="@Model.PaginationLink(Model.Page - 1)" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">← Prev</a>
            }
            @if (Model.HasNextPage)
            {
                <a href="@Model.PaginationLink(Model.Page + 1)" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">Next →</a>
            }
        </div>
    </div>
}

@page "{id}"
@model Purview.EventSourcing.Samples.Web.Pages.Orders.EditModel
@{
    ViewData["Title"] = $"Edit Order";
}
@using Purview.EventSourcing.Samples.Domain

@if (Model.Order == null)
{
    <p class="text-gray-500">Order not found.</p>
    return;
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Orders</a>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Add Line Item (Draft only) -->
    @if (Model.Order.Status == OrderStatus.Draft)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-base font-semibold mb-4">Add Line Item</h2>
            <form method="post" asp-page-handler="AddLineItem">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Product ID *</label>
                        <input name="productId" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Product Name *</label>
                        <input name="productName" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Quantity *</label>
                            <input name="quantity" type="number" min="1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Unit Price *</label>
                            <input name="unitPrice" type="number" step="0.01" min="0" value="0.00" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
                        </div>
                    </div>
                </div>
                <button type="submit" class="mt-4 w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Add Item</button>
            </form>
        </div>

        <!-- Remove Line Item -->
        @if (Model.Order.LineItems.Length > 0)
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-base font-semibold mb-4">Remove Line Item</h2>
                <form method="post" asp-page-handler="RemoveLineItem">
                    <input type="hidden" name="id" value="@Model.Order.Id()" />
                    <select name="productId" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm mb-3">
                        @foreach (var item in Model.Order.LineItems)
                        {
                            <option value="@item.ProductId">@item.ProductName (x@item.Quantity)</option>
                        }
                    </select>
                    <button type="submit" class="w-full px-4 py-2 bg-red-50 text-red-700 text-sm rounded-lg hover:bg-red-100 transition-colors">Remove Item</button>
                </form>
            </div>
        }

        <!-- Set Shipping Address -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-base font-semibold mb-4">Set Shipping Address</h2>
            <form method="post" asp-page-handler="SetShippingAddress">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <textarea name="address" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm mb-3 focus:outline-none focus:ring-2 focus:ring-slate-400" required>@Model.Order.ShippingAddress</textarea>
                <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Set Address</button>
            </form>
        </div>
    }

    <!-- Update Notes -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Notes</h2>
        <form method="post" asp-page-handler="UpdateNotes">
            <input type="hidden" name="id" value="@Model.Order.Id()" />
            <textarea name="notes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm mb-3 focus:outline-none focus:ring-2 focus:ring-slate-400">@Model.Order.Notes</textarea>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Notes</button>
        </form>
    </div>
</div>

<!-- Status machine actions -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-base font-semibold mb-4">
        Order Actions
        <span class="ml-2 px-2 py-1 rounded-full text-xs font-medium @StatusBadge(Model.Order.Status)">@Model.Order.Status</span>
    </h2>
    <div class="flex flex-wrap gap-3">
        @if (Model.Order.Status == OrderStatus.Draft)
        {
            <form method="post" asp-page-handler="Confirm">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors"
                        onclick="return confirm('Confirm this order?')">✓ Confirm Order</button>
            </form>
        }
        @if (Model.Order.Status == OrderStatus.Confirmed)
        {
            <form method="post" asp-page-handler="Ship">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <button type="submit" class="px-4 py-2 bg-amber-600 text-white text-sm rounded-lg hover:bg-amber-700 transition-colors"
                        onclick="return confirm('Mark as shipped?')">🚚 Ship Order</button>
            </form>
        }
        @if (Model.Order.Status == OrderStatus.Shipped)
        {
            <form method="post" asp-page-handler="Complete">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <button type="submit" class="px-4 py-2 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 transition-colors"
                        onclick="return confirm('Complete this order?')">✓ Complete Order</button>
            </form>
        }
        @if (Model.Order.Status != OrderStatus.Completed && Model.Order.Status != OrderStatus.Cancelled)
        {
            <form method="post" asp-page-handler="Cancel">
                <input type="hidden" name="id" value="@Model.Order.Id()" />
                <button type="submit" class="px-4 py-2 bg-red-50 text-red-700 text-sm rounded-lg hover:bg-red-100 transition-colors"
                        onclick="return confirm('Cancel this order?')">✗ Cancel Order</button>
            </form>
        }
    </div>
</div>

@functions {
    static string StatusBadge(OrderStatus status) => status switch {
        OrderStatus.Draft => "bg-gray-100 text-gray-600",
        OrderStatus.Confirmed => "bg-blue-100 text-blue-700",
        OrderStatus.Shipped => "bg-amber-100 text-amber-700",
        OrderStatus.Completed => "bg-green-100 text-green-700",
        OrderStatus.Cancelled => "bg-red-100 text-red-600",
        _ => "bg-gray-100 text-gray-500"
    };
}

@page "{id}"
@model Purview.EventSourcing.Samples.Web.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = $"Order Details";
}
@using Purview.EventSourcing.Samples.Domain

@if (Model.Order == null)
{
    <p class="text-gray-500">Order not found.</p>
    return;
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Orders</a>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="md:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <div class="flex items-start justify-between mb-6">
            <div>
                <h2 class="text-xl font-semibold font-mono">@Model.Order.Id()[..8]…</h2>
                <span class="mt-1 px-2 py-1 rounded-full text-xs font-medium @StatusBadge(Model.Order.Status)">@Model.Order.Status</span>
            </div>
            <a asp-page="Edit" asp-route-id="@Model.Order.Id()" class="px-4 py-2 text-sm bg-slate-700 text-white rounded-lg hover:bg-slate-600 transition-colors">Edit</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-8 gap-y-4 text-sm">
            <div>
                <dt class="font-medium text-gray-500">Customer ID</dt>
                <dd class="mt-1 font-mono text-xs">@Model.Order.CustomerId</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-500">Total Amount</dt>
                <dd class="mt-1 text-lg font-semibold">@Model.Order.TotalAmount.ToString("C")</dd>
            </div>
            @if (Model.Order.ShippingAddress != null)
            {
                <div>
                    <dt class="font-medium text-gray-500">Shipping Address</dt>
                    <dd class="mt-1">@Model.Order.ShippingAddress</dd>
                </div>
            }
            @if (Model.Order.Notes != null)
            {
                <div>
                    <dt class="font-medium text-gray-500">Notes</dt>
                    <dd class="mt-1">@Model.Order.Notes</dd>
                </div>
            }
            @if (Model.Order.ShippedAt.HasValue)
            {
                <div>
                    <dt class="font-medium text-gray-500">Shipped At</dt>
                    <dd class="mt-1">@Model.Order.ShippedAt.Value.ToString("g")</dd>
                </div>
            }
            @if (Model.Order.CompletedAt.HasValue)
            {
                <div>
                    <dt class="font-medium text-gray-500">Completed At</dt>
                    <dd class="mt-1">@Model.Order.CompletedAt.Value.ToString("g")</dd>
                </div>
            }
        </dl>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-sm font-semibold text-gray-600 mb-4">Event Store Info</h3>
        <dl class="space-y-3 text-sm">
            <div>
                <dt class="text-gray-500 text-xs">Saved Version</dt>
                <dd class="font-mono font-medium">v@Model.Order.Details.SavedVersion</dd>
            </div>
            <div>
                <dt class="text-gray-500 text-xs">Full ID</dt>
                <dd class="font-mono text-xs text-gray-400 break-all">@Model.Order.Id()</dd>
            </div>
        </dl>
    </div>
</div>

@if (Model.Order.LineItems.Length > 0)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h3 class="text-base font-semibold">Line Items (@Model.Order.LineItems.Length)</h3>
        </div>
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Product</th>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Product ID</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Qty</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Unit Price</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model.Order.LineItems)
                {
                    <tr>
                        <td class="px-5 py-3 font-medium">@item.ProductName</td>
                        <td class="px-5 py-3 font-mono text-xs text-gray-400">@item.ProductId</td>
                        <td class="px-5 py-3 text-right">@item.Quantity</td>
                        <td class="px-5 py-3 text-right">@item.UnitPrice.ToString("C")</td>
                        <td class="px-5 py-3 text-right font-medium">@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                    </tr>
                }
                <tr class="bg-gray-50 font-semibold">
                    <td colspan="4" class="px-5 py-3 text-right">Total</td>
                    <td class="px-5 py-3 text-right">@Model.Order.TotalAmount.ToString("C")</td>
                </tr>
            </tbody>
        </table>
    </div>
}

@functions {
    static string StatusBadge(OrderStatus status) => status switch {
        OrderStatus.Draft => "bg-gray-100 text-gray-600",
        OrderStatus.Confirmed => "bg-blue-100 text-blue-700",
        OrderStatus.Shipped => "bg-amber-100 text-amber-700",
        OrderStatus.Completed => "bg-green-100 text-green-700",
        OrderStatus.Cancelled => "bg-red-100 text-red-600",
        _ => "bg-gray-100 text-gray-500"
    };
}

@page "{id}"
@model Purview.EventSourcing.Samples.Web.Pages.Inventory.DetailsModel
@{
    ViewData["Title"] = Model.Item?.ProductName ?? "Inventory Details";
}

@if (Model.Item == null)
{
    <p class="text-gray-500">Inventory item not found.</p>
    return;
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Inventory</a>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <div class="flex items-start justify-between mb-6">
            <h2 class="text-xl font-semibold">@Model.Item.ProductName</h2>
            <a asp-page="Edit" asp-route-id="@Model.Item.Id()" class="px-4 py-2 text-sm bg-slate-700 text-white rounded-lg hover:bg-slate-600 transition-colors">Edit</a>
        </div>

        <!-- Stock summary cards -->
        <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-gray-50 rounded-lg p-4 text-center">
                <p class="text-2xl font-bold text-slate-700">@Model.Item.QuantityOnHand</p>
                <p class="text-xs text-gray-500 mt-1">On Hand</p>
            </div>
            <div class="bg-amber-50 rounded-lg p-4 text-center">
                <p class="text-2xl font-bold text-amber-600">@Model.Item.ReservedQuantity</p>
                <p class="text-xs text-gray-500 mt-1">Reserved</p>
            </div>
            <div class="@(Model.Item.AvailableQuantity <= 0 ? "bg-red-50" : "bg-green-50") rounded-lg p-4 text-center">
                <p class="text-2xl font-bold @(Model.Item.AvailableQuantity <= 0 ? "text-red-600" : "text-green-700")">@Model.Item.AvailableQuantity</p>
                <p class="text-xs text-gray-500 mt-1">Available</p>
            </div>
        </div>

        <dl class="grid grid-cols-2 gap-x-8 gap-y-4 text-sm">
            <div>
                <dt class="font-medium text-gray-500">Product ID</dt>
                <dd class="mt-1 font-mono text-xs">@Model.Item.ProductId</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-500">Aggregate ID</dt>
                <dd class="mt-1 font-mono text-xs text-gray-400">@Model.Item.Id()</dd>
            </div>
        </dl>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-sm font-semibold text-gray-600 mb-4">Event Store Info</h3>
        <dl class="space-y-3 text-sm">
            <div>
                <dt class="text-gray-500 text-xs">Saved Version</dt>
                <dd class="font-mono font-medium">v@Model.Item.Details.SavedVersion</dd>
            </div>
            <div>
                <dt class="text-gray-500 text-xs">Aggregate Type</dt>
                <dd class="font-mono text-xs text-gray-400">@Model.Item.AggregateType</dd>
            </div>
        </dl>
    </div>
</div>

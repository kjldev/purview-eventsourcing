@page
@model Purview.EventSourcing.Samples.Web.Pages.Customer.Catalog.OrderModel
@{
    ViewData["Title"] = "Place Order";
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Catalog</a>

@if (Model.InventoryItem == null)
{
    <p class="text-gray-500">Product not found.</p>
    return;
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <!-- Product info -->
        <div class="mb-6 pb-6 border-b border-gray-100">
            <h2 class="text-xl font-semibold text-gray-900">@Model.InventoryItem.ProductName</h2>
            <p class="text-xs text-gray-400 font-mono mt-1">@Model.InventoryItem.ProductId</p>
            <div class="flex items-center gap-6 mt-3">
                <div>
                    <p class="text-2xl font-bold text-slate-800">@Model.UnitPrice.ToString("C")</p>
                    <p class="text-xs text-gray-500">per unit</p>
                </div>
                <div>
                    <p class="text-lg font-semibold text-green-700">@Model.InventoryItem.AvailableQuantity</p>
                    <p class="text-xs text-gray-500">available</p>
                </div>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="mb-5 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"></div>

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InventoryId" />
            <div class="space-y-4">
                <div>
                    <label asp-for="Quantity" class="block text-sm font-medium text-gray-700 mb-1">Quantity *</label>
                    <input asp-for="Quantity" type="number" min="1" max="@Model.InventoryItem.AvailableQuantity"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" required />
                    <span asp-validation-for="Quantity" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="ShippingAddress" class="block text-sm font-medium text-gray-700 mb-1">Shipping Address *</label>
                    <textarea asp-for="ShippingAddress" rows="3"
                              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"
                              placeholder="Enter your delivery address" required></textarea>
                    <span asp-validation-for="ShippingAddress" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="mt-6 flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">
                    Place Order
                </button>
                <a asp-page="Index" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">Cancel</a>
            </div>
        </form>
    </div>
</div>

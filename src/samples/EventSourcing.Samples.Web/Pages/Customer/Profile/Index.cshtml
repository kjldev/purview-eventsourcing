@page
@model Purview.EventSourcing.Samples.Web.Pages.Customer.Profile.IndexModel
@{
    ViewData["Title"] = "My Profile";
}

@if (Model.CurrentCustomer == null)
{
    <p class="text-gray-500">Customer not found.</p>
    return;
}

<div class="mb-4">
    <p class="text-sm text-gray-500">
        Status:
        @if (Model.CurrentCustomer.IsActive)
        {
            <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">Active</span>
        }
        else
        {
            <span class="px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactive</span>
        }
    </p>
</div>

<!-- Combined Update Profile -->
<div class="bg-white rounded-xl shadow-sm border border-blue-100 p-6 mb-6">
    <h2 class="text-base font-semibold mb-4">Update Profile</h2>
    <form method="post" asp-page-handler="UpdateAll">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input name="newName" type="text" value="@Model.CurrentCustomer.Name"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" required />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input name="newEmail" type="email" value="@Model.CurrentCustomer.Email"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" required />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input name="phoneNumber" type="tel" value="@Model.CurrentCustomer.PhoneNumber"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
        </div>
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">Save All Changes</button>
    </form>
</div>

<p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-3">Individual updates</p>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Change Name -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Name</h2>
        <form method="post" asp-page-handler="ChangeName">
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input name="newName" type="text" value="@Model.CurrentCustomer.Name"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Name</button>
        </form>
    </div>

    <!-- Change Email -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Email</h2>
        <form method="post" asp-page-handler="ChangeEmail">
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input name="newEmail" type="email" value="@Model.CurrentCustomer.Email"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Email</button>
        </form>
    </div>

    <!-- Change Phone -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Phone</h2>
        <form method="post" asp-page-handler="ChangePhone">
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                <input name="phoneNumber" type="tel" value="@Model.CurrentCustomer.PhoneNumber"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Phone</button>
        </form>
    </div>
</div>

<div class="mt-6 bg-gray-50 rounded-xl border border-gray-100 p-4 text-sm text-gray-600">
    <span class="font-medium">@Model.CurrentCustomer.Name</span> ·
    <span>@Model.CurrentCustomer.Email</span> ·
    <span class="font-mono text-xs text-gray-400">v@(Model.CurrentCustomer.Details.SavedVersion)</span>
</div>

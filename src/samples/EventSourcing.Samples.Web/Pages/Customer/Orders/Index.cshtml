@page
@model Purview.EventSourcing.Samples.Web.Pages.Customer.Orders.IndexModel
@using Purview.EventSourcing.Samples.Domain
@{
    ViewData["Title"] = "My Orders";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        @if (Model.CurrentCustomer != null)
        {
            <p class="text-gray-600">Orders for <span class="font-semibold">@Model.CurrentCustomer.Name</span></p>
        }
        <p class="text-sm text-gray-400">@Model.TotalCount order(s) — page @Model.Page of @Model.TotalPages</p>
    </div>
</div>

@if (Model.Orders.Count == 0)
{
    <div class="text-center py-16 text-gray-400">
        <p class="text-5xl mb-3">📋</p>
        <p class="text-lg font-medium">No orders yet</p>
        <p class="text-sm mt-1"><a asp-page="/Customer/Catalog/Index" class="underline text-blue-600">Browse the catalog</a> to place your first order.</p>
    </div>
}
else
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Order ID</th>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Status</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Total</th>
                    <th class="text-right px-5 py-3 font-medium text-gray-600">Items</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var order in Model.Orders)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-5 py-3 font-mono text-xs text-gray-500">@(order.Id().Length >= 8 ? order.Id()[..8] : order.Id())…</td>
                        <td class="px-5 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-medium @StatusBadge(order.Status)">@order.Status</span>
                            @if (order.Status == OrderStatus.Draft)
                            {
                                <span class="ml-2 text-xs text-amber-600">✏ Editable</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right font-semibold">@order.TotalAmount.ToString("C")</td>
                        <td class="px-5 py-3 text-right text-gray-500">@order.LineItems.Length</td>
                        <td class="px-5 py-3 text-right">
                            <a asp-page="Details" asp-route-id="@order.Id()" class="text-blue-600 hover:underline">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4 text-sm text-gray-600">
        <span>Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, (int)Model.TotalCount)) of @Model.TotalCount</span>
        <div class="flex gap-2">
            @if (Model.HasPrevPage)
            {
                <a asp-page="Index" asp-route-page="@(Model.Page-1)" asp-route-pageSize="@Model.PageSize" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">← Prev</a>
            }
            @if (Model.HasNextPage)
            {
                <a asp-page="Index" asp-route-page="@(Model.Page+1)" asp-route-pageSize="@Model.PageSize" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">Next →</a>
            }
        </div>
    </div>
}

@functions {
    static string StatusBadge(OrderStatus status) => status switch {
        OrderStatus.Draft => "bg-gray-100 text-gray-600",
        OrderStatus.Confirmed => "bg-blue-100 text-blue-700",
        OrderStatus.Shipped => "bg-amber-100 text-amber-700",
        OrderStatus.Completed => "bg-green-100 text-green-700",
        OrderStatus.Cancelled => "bg-red-100 text-red-600",
        _ => "bg-gray-100 text-gray-500"
    };
}

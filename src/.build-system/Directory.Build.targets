<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<Target
		Name="ValidateRootNamespacePrefix"
		BeforeTargets="Compile"
		Label="Validates the NamespacePrefix Prefix is set."
	>
		<Error
				Text="The NamespacePrefix property has not been set. To fix, set the `NamespacePrefix` in the `PropertyGroup` of either the .csproj file, or a Directory.Build.props file."
				ContinueOnError="false"
				Condition="'$(NamespacePrefix)' == ''"
				Code="NamespacePrefixNoSet"
				File="$(MSBuildProjectFile)"
		/>
	</Target>

	<Target
			Name="InternalsVisibleTo"
			BeforeTargets="BeforeCompile"
			Condition="'$(IsCSharpProject)' == 'true' AND '$(IsTestProject)' == 'false'"
			Inputs="@TestType"
			Outputs="%(TestType.Identity)"
			Label="Generates InternalsVisibleToAttribute for Non-Test Projects based on Defined Testing Types"
	>
		<ItemGroup>
			<Message Importance="High" Text="Adding InternalsVisibleToAttribute for $(MSBuildProjectName).%(TestType.Identity)Tests" />
			<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
				<_Parameter1>$(MSBuildProjectName).%(TestType.Identity)Tests</_Parameter1>
			</AssemblyAttribute>
		</ItemGroup>
	</Target>

	<Target
		Name="GenerateAssemblyInfoClass"
		BeforeTargets="BeforeCompile"
	>
		<WriteLinesToFile
			File="$(IntermediateOutputPath)/Properties/$(AutoGeneratedAssemblyInfoFile)"
			Lines="namespace $(RootNamespace)%3B

static class AssemblyInfo
{
    public const string RootNamespace = &quot;$(RootNamespace)&quot;%3B
    public const string Name = &quot;$(AssemblyName)&quot;%3B
    public const string Version = &quot;$(Version)&quot;%3B
    public const string Company = &quot;$(Company)&quot;%3B
    public const string Copyright = &quot;$(Copyright)&quot;%3B
}
"
			Overwrite="true"/>

		<ItemGroup>
			<Compile Include="$(IntermediateOutputPath)/Properties/$(AutoGeneratedAssemblyInfoFile)" />
		</ItemGroup>
	</Target>
</Project>

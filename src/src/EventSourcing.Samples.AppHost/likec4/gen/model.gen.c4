      link https://localhost:17134/structuredlogs/resource/web-rebuilder 'Dashboard: Structured Logs'
      metadata {
        aspire-name 'web-rebuilder'
        aspire-type 'Executable'
      }
    }
  }

  redisinsight -> redis 'RedisInsight'
  web -> eventstore_sqlserver
  web -> blob_storage
  web -> redis
}

views {
  view index {
    title 'Architecture'
    include *
    style element.tag = #aspire-run-state-starting {
      color sky
    }
    style element.tag = #aspire-run-state-waiting {
      color sky
    }
    style element.tag = #aspire-run-state-running {
      color green
    }
    style element.tag = #aspire-run-state-stopping {
      color slate
      opacity 60%
    }
    style element.tag = #aspire-run-state-exited {
      color muted
      opacity 30%
    }
    style element.tag = #aspire-run-state-finished {
      color muted
      opacity 30%
    }
    style element.tag = #aspire-run-state-runtimeunhealthy {
      color amber
    }
    style element.tag = #aspire-run-state-failedtostart {
      color red
    }
  }
}

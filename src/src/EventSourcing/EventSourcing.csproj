<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup Label="NuGet Package Values">
    <IsPackable>true</IsPackable>
    <Title>Purview Event Sourcing</Title>
    <Description>Core abstractions, aggregate types, facades, transactions, and dependency injection extensions for building event-sourced .NET applications.</Description>
    <PackageTags>$(PackageTags);purview;kjldev;dotnet;event-sourcing;eventstore;event-store;aggregate;domain-driven-design;</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference
      Include="..\EventSourcing.SourceGenerator\EventSourcing.SourceGenerator.csproj"
      OutputItemType="Analyzer"
      ReferenceOutputAssembly="false"
      PrivateAssets="all"
    />
  </ItemGroup>

  <!-- Ship the generator DLL and build props file inside the NuGet package. -->
  <Target Name="IncludeAnalyzerInPackage" BeforeTargets="_GetPackageFiles">
    <MSBuild
      Projects="..\EventSourcing.SourceGenerator\EventSourcing.SourceGenerator.csproj"
      Targets="GetTargetPath"
      Properties="Configuration=$(Configuration)"
      RebaseOutputs="true"
    >
      <Output TaskParameter="TargetOutputs" ItemName="_AnalyzerDll" />
    </MSBuild>
    <ItemGroup>
      <None
        Include="@(_AnalyzerDll)"
        Pack="true"
        PackagePath="analyzers/dotnet/cs"
        Visible="false"
      />
      <None
        Include="$(MSBuildThisFileDirectory)build\EventSourcing.props"
        Pack="true"
        PackagePath="build"
        Visible="false"
      />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="Microsoft.Extensions.Caching.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
</Project>

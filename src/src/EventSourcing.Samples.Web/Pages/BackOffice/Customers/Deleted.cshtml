@page
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Customers.DeletedModel
@{
    ViewData["Title"] = "Archived Customers";
}

<div class="mb-6">
    <a asp-page="Index" class="text-sm text-slate-500 hover:underline">← Back to Customers</a>
</div>

@if (Model.DeletedCustomers.Count == 0)
{
    <div class="text-center py-16 text-gray-400">
        <p class="text-5xl mb-3">🗄</p>
        <p class="text-lg font-medium">No archived customers</p>
    </div>
}
else
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Name</th>
                    <th class="text-left px-5 py-3 font-medium text-gray-600">Email</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var customer in Model.DeletedCustomers)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-5 py-3 font-medium text-gray-500">@customer.Name</td>
                        <td class="px-5 py-3 text-gray-400">@customer.Email</td>
                        <td class="px-5 py-3 text-right">
                            <form method="post" asp-page-handler="Restore" asp-route-id="@customer.Id()" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-green-600 hover:underline text-sm">Restore</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@page "{id}"
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.Customers.EditModel
@{
    ViewData["Title"] = $"Edit — {Model.Customer?.Name}";
}

@if (Model.Customer == null)
{
    <p class="text-gray-500">Customer not found.</p>
    return;
}

<a asp-page="Index" class="text-sm text-slate-500 hover:underline mb-4 inline-block">← Back to Customers</a>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Change Name -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Name</h2>
        <form method="post" asp-page-handler="ChangeName">
            <input type="hidden" name="id" value="@Model.Customer.Id()" />
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">New Name</label>
                <input name="newName" type="text" value="@Model.Customer.Name"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Name</button>
        </form>
    </div>

    <!-- Change Email -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Email</h2>
        <form method="post" asp-page-handler="ChangeEmail">
            <input type="hidden" name="id" value="@Model.Customer.Id()" />
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">New Email</label>
                <input name="newEmail" type="email" value="@Model.Customer.Email"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Email</button>
        </form>
    </div>

    <!-- Change Phone -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Change Phone</h2>
        <form method="post" asp-page-handler="ChangePhone">
            <input type="hidden" name="id" value="@Model.Customer.Id()" />
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                <input name="phoneNumber" type="tel" value="@Model.Customer.PhoneNumber"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Update Phone</button>
        </form>
    </div>

    <!-- Status actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold mb-4">Status</h2>
        <p class="text-sm text-gray-500 mb-4">
            Current:
            @if (Model.Customer.IsActive)
            {
                <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">Active</span>
            }
            else
            {
                <span class="px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactive</span>
            }
        </p>
        @if (Model.Customer.IsActive)
        {
            <form method="post" asp-page-handler="Deactivate">
                <input type="hidden" name="id" value="@Model.Customer.Id()" />
                <button type="submit" class="w-full px-4 py-2 bg-amber-100 text-amber-700 text-sm rounded-lg hover:bg-amber-200 transition-colors">Deactivate</button>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="Reactivate">
                <input type="hidden" name="id" value="@Model.Customer.Id()" />
                <button type="submit" class="w-full px-4 py-2 bg-green-100 text-green-700 text-sm rounded-lg hover:bg-green-200 transition-colors">Reactivate</button>
            </form>
        }
    </div>
</div>

<div class="mt-6 bg-gray-50 rounded-xl border border-gray-100 p-4 text-sm text-gray-600">
    <span class="font-medium">@Model.Customer.Name</span> ·
    <span>@Model.Customer.Email</span> ·
    <span class="font-mono text-xs text-gray-400">v@(Model.Customer.Details.SavedVersion)</span>
</div>

@page
@model Purview.EventSourcing.Samples.Web.Pages.BackOffice.IndexModel
@{
    ViewData["Title"] = "Back Office Dashboard";
}

<div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">📦</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.UniqueProductCount</p>
            <p class="text-xs text-gray-500">Unique Products</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">🏭</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.InventoryItemCount</p>
            <p class="text-xs text-gray-500">Inventory Items</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">✅</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.TotalAvailableStock</p>
            <p class="text-xs text-gray-500">Available Stock</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">✏️</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.DraftOrderCount</p>
            <p class="text-xs text-gray-500">Draft Orders</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">🚚</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.ActiveOrderCount</p>
            <p class="text-xs text-gray-500">Active Orders</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-3">
        <div class="text-3xl">🏁</div>
        <div>
            <p class="text-2xl font-bold text-slate-800">@Model.CompletedOrderCount</p>
            <p class="text-xs text-gray-500">Completed/Cancelled</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">👤 Customers</h2>
        <p class="text-sm text-gray-500 mb-4">Manage customer accounts, create new customers, and edit profiles.</p>
        <a asp-page="/BackOffice/Customers/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Manage Customers →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">📦 Catalog</h2>
        <p class="text-sm text-gray-500 mb-4">Manage inventory items, update product names and locations.</p>
        <a asp-page="/BackOffice/Catalog/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Manage Catalog →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">🏭 Stock</h2>
        <p class="text-sm text-gray-500 mb-4">Track stock levels, receive goods, reserve and transfer stock.</p>
        <a asp-page="/BackOffice/Stock/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Manage Stock →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-700 mb-3">🔎 Audit</h2>
        <p class="text-sm text-gray-500 mb-4">Review aggregate event histories with version and time range filters.</p>
        <a asp-page="/BackOffice/Audit/Index" class="inline-block px-4 py-2 bg-slate-700 text-white text-sm rounded-lg hover:bg-slate-600 transition-colors">Open Audit Portal →</a>
    </div>
</div>

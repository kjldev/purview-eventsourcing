@page
@model Purview.EventSourcing.Samples.Web.Pages.Customer.Cart.IndexModel
@using Purview.EventSourcing.Samples.Web.Infrastructure
@{
    ViewData["Title"] = "Your Cart";
}

@if (Model.CartItems.Count == 0)
{
    <div class="text-center py-20 text-gray-400">
        <p class="text-6xl mb-4">🛒</p>
        <p class="text-xl font-medium mb-2">Your cart is empty</p>
        <p class="text-sm mb-6">Head to the storefront to add products.</p>
        <a asp-page="/Customer/Catalog/Index" class="px-6 py-3 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">Browse Products</a>
    </div>
    return;
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Cart Items -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-base font-semibold">Cart Items (@Model.CartItems.Sum(c => c.Quantity))</h2>
                <form method="post" asp-page-handler="ClearCart">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-sm text-red-400 hover:text-red-600 hover:underline"
                            onclick="return confirm('Clear all items?')">Clear cart</button>
                </form>
            </div>
            <div class="divide-y divide-gray-50">
                @foreach (var item in Model.CartItems)
                {
                    <div class="px-6 py-4 flex items-center gap-4">
                        <div class="flex-1">
                            <p class="font-medium text-gray-900">@item.ProductName</p>
                            <p class="text-xs text-gray-400 font-mono mt-0.5">@item.ProductId</p>
                        </div>
                        <div class="text-right mr-4">
                            <p class="text-sm text-gray-500">@item.UnitPrice.ToString("C") each</p>
                            <p class="font-semibold">@((item.Quantity * item.UnitPrice).ToString("C"))</p>
                        </div>
                        <!-- Quantity form -->
                        <form method="post" asp-page-handler="UpdateQuantity" class="flex items-center gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="inventoryId" value="@item.InventoryId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="999"
                                   class="w-16 px-2 py-1 border border-gray-300 rounded text-sm text-center" />
                            <button type="submit" class="text-xs text-slate-600 hover:underline">Update</button>
                        </form>
                        <!-- Remove form -->
                        <form method="post" asp-page-handler="RemoveItem">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="inventoryId" value="@item.InventoryId" />
                            <button type="submit" class="text-red-400 hover:text-red-600 text-lg leading-none"
                                    onclick="return confirm('Remove this item?')">×</button>
                        </form>
                    </div>
                }
            </div>
        </div>
        <div class="mt-4">
            <a asp-page="/Customer/Catalog/Index" class="text-sm text-slate-500 hover:underline">← Continue Shopping</a>
        </div>
    </div>

    <!-- Checkout Panel -->
    <div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sticky top-6">
            <h2 class="text-base font-semibold mb-4">Order Summary</h2>
            <div class="space-y-2 text-sm mb-4">
                @foreach (var item in Model.CartItems)
                {
                    <div class="flex justify-between">
                        <span class="text-gray-600">@item.ProductName × @item.Quantity</span>
                        <span>@((item.Quantity * item.UnitPrice).ToString("C"))</span>
                    </div>
                }
                <div class="border-t pt-2 flex justify-between font-semibold text-base">
                    <span>Total</span>
                    <span>@Model.CartTotal.ToString("C")</span>
                </div>
            </div>

            <form method="post" asp-page-handler="Checkout">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Shipping Address <span class="text-gray-400 font-normal">(optional)</span></label>
                    <textarea asp-for="ShippingAddress" rows="3"
                              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"
                              placeholder="Enter your shipping address…"></textarea>
                </div>
                <button type="submit"
                        class="w-full px-4 py-3 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors">
                    ✓ Place Order
                </button>
            </form>
        </div>
    </div>
</div>

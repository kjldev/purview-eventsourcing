<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Event Sourcing Sample</title>
    <script src="https://unpkg.com/@@tailwindcss/browser@@4"></script>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex">
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
        var isCustomer = currentPage.StartsWith("/Customer");
        var isBackOffice = currentPage.StartsWith("/BackOffice");
    }

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-800 text-white flex flex-col min-h-screen">
        <div class="px-6 py-5 border-b border-slate-700">
            <a asp-page="/Index" class="text-xl font-bold tracking-tight text-white hover:text-slate-200">
                🗃 Event Sourcing
            </a>
            <p class="text-xs text-slate-400 mt-1">Sample Application</p>
        </div>
        <nav class="flex-1 px-4 py-4 space-y-1">
            @if (isCustomer)
            {
                var selectedCustomerId = Context.Session.GetString("selectedCustomerId");
                var hasCustomer = !string.IsNullOrEmpty(selectedCustomerId);
                <p class="px-2 py-1 text-xs font-semibold text-slate-400 uppercase tracking-wider mt-2">Customer Portal</p>
                @if (hasCustomer)
                {
                    var cartCount = Context.Session.GetCartCount();
                    <a asp-page="/Customer/Catalog/Index"
                       class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/Customer/Catalog") ? "bg-slate-700 text-white" : "")">
                        🛒 Storefront
                    </a>
                    <a asp-page="/Customer/Cart/Index"
                       class="flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/Customer/Cart") ? "bg-slate-700 text-white" : "")">
                        <span>🧺 My Cart</span>
                        @if (cartCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold bg-blue-500 text-white rounded-full">@cartCount</span>
                        }
                    </a>
                    <a asp-page="/Customer/Orders/Index"
                       class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/Customer/Orders") ? "bg-slate-700 text-white" : "")">
                        📋 My Orders
                    </a>
                    <a asp-page="/Customer/Profile/Index"
                       class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/Customer/Profile") ? "bg-slate-700 text-white" : "")">
                        👤 My Profile
                    </a>
                    <div class="pt-4 border-t border-slate-700 mt-4">
                        <a asp-page="/Customer/Index"
                           class="flex items-center px-3 py-2 rounded-md text-sm text-slate-400 hover:text-white hover:bg-slate-700 transition-colors @(currentPage == "/Customer/Index" ? "bg-slate-700 text-white" : "")">
                            🔄 Change Profile
                        </a>
                        <a asp-page="/Index" class="flex items-center px-3 py-2 rounded-md text-sm text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                            ← Back to Portal
                        </a>
                    </div>
                }
                else
                {
                    <p class="px-3 py-2 text-sm text-slate-400">Select a profile below to browse the store.</p>
                    <div class="pt-4 border-t border-slate-700 mt-4">
                        <a asp-page="/Index" class="flex items-center px-3 py-2 rounded-md text-sm text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                            ← Back to Portal
                        </a>
                    </div>
                }
            }
            else if (isBackOffice)
            {
                <p class="px-2 py-1 text-xs font-semibold text-slate-400 uppercase tracking-wider mt-2">Back Office</p>
                <a asp-page="/BackOffice/Index"
                   class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage == "/BackOffice/Index" ? "bg-slate-700 text-white" : "")">
                    📊 Dashboard
                </a>
                <p class="px-2 py-1 text-xs font-semibold text-slate-400 uppercase tracking-wider mt-3">Management</p>
                <a asp-page="/BackOffice/Customers/Index"
                   class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/BackOffice/Customers") ? "bg-slate-700 text-white" : "")">
                    👤 Customers
                </a>
                <a asp-page="/BackOffice/Catalog/Index"
                   class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/BackOffice/Catalog") ? "bg-slate-700 text-white" : "")">
                    📦 Catalog
                </a>
                <a asp-page="/BackOffice/Stock/Index"
                   class="flex items-center px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors @(currentPage.StartsWith("/BackOffice/Stock") ? "bg-slate-700 text-white" : "")">
                    🏭 Stock
                </a>
                <div class="pt-4 border-t border-slate-700 mt-4">
                    <a asp-page="/Index" class="flex items-center px-3 py-2 rounded-md text-sm text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                        ← Back to Portal
                    </a>
                </div>
            }
            else
            {
                <p class="px-2 py-1 text-xs font-semibold text-slate-400 uppercase tracking-wider mt-2">Navigation</p>
                <p class="px-3 py-2 text-sm text-slate-400">Choose your portal above.</p>
            }
        </nav>
        <div class="px-6 py-4 border-t border-slate-700 text-xs text-slate-500">
            .NET 10 · Event Sourcing
        </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 flex flex-col">
        <!-- Top bar -->
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
            <h1 class="text-lg font-semibold text-gray-800">@ViewData["Title"]</h1>
        </header>

        <!-- Flash messages -->
        @if (TempData["Success"] != null)
        {
            <div class="mx-8 mt-4 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
                ✅ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mx-8 mt-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
                ❌ @TempData["Error"]
            </div>
        }

        <!-- Page body -->
        <div class="flex-1 px-8 py-6">
            @RenderBody()
        </div>
    </main>
</body>
</html>

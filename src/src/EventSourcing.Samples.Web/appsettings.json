{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EventStore:SqlServer": {
    "AutoCreateTable": true,
    "TableName": "Events",
    "SchemaName": "dbo"
  },
  "EventStore:SqlServerSnapshot": {
    "AutoCreateTable": true,
    "TableName": "Snapshots",
    "SchemaName": "dbo"
  }
}

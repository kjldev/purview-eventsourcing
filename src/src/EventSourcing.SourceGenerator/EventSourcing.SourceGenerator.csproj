<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<LangVersion>12</LangVersion>
		<EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<IsPackable>true</IsPackable>
		<PackageId>Purview.EventSourcing.SourceGenerator</PackageId>
		<Title>Purview Event Sourcing Source Generator</Title>
		<Description>Roslyn source generator for Purview EventSourcing aggregates that emits event types, registration code, and typed command methods from attributed partial classes.</Description>
		<Authors>Kieron Lanning</Authors>
		<PackageTags>$(PackageTags);purview;kjldev;dotnet;roslyn;source-generator;event-sourcing;aggregate;</PackageTags>
		<DevelopmentDependency>true</DevelopmentDependency>
		<SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
		<CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
		<IsRoslynComponent>true</IsRoslynComponent>
		<!-- snupkg requires standard build output, which this analyzer package suppresses. -->
		<SymbolPackageFormat>symbols.nupkg</SymbolPackageFormat>
		<TargetsForTfmSpecificDebugSymbolsInPackage>$(TargetsForTfmSpecificDebugSymbolsInPackage);PackSourceGeneratorSymbols</TargetsForTfmSpecificDebugSymbolsInPackage>
		<RootNamespace>Purview.EventSourcing.SourceGenerator</RootNamespace>
		<Nullable>enable</Nullable>
		<!-- Exclude Purview.Telemetry.SourceGenerator since this is a netstandard2.0 analyzer project -->
		<ExcludePurviewTelemetry>true</ExcludePurviewTelemetry>
		<NoWarn>$(NoWarn);CS8632;RS1035;RS1036</NoWarn>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
		<PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
	</ItemGroup>
	<ItemGroup>
		<Compile Remove="Templates\Sources\**\*.cs" />
		<EmbeddedResource Include="Templates\Sources\**\*.cs" />
	</ItemGroup>
	<!-- Pack the generator into the analyzer slot and surface its PDB in the symbols package. -->
	<ItemGroup>
		<None
			Include="$(OutputPath)\$(AssemblyName).dll"
			Pack="true"
			PackagePath="analyzers/dotnet/cs"
			Visible="false"
		/>
	</ItemGroup>
	<Target Name="PackSourceGeneratorSymbols">
		<ItemGroup>
			<TfmSpecificDebugSymbolsFile
				Include="$(OutputPath)\$(AssemblyName).pdb"
				Condition="Exists('$(OutputPath)\$(AssemblyName).pdb')"
			/>
		</ItemGroup>
	</Target>
</Project>
